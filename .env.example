# Generate a random string with: openssl rand -hex 32
JWT_SECRET=replace-with-a-random-string
JWT_EXPIRE_MINUTES=480

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password
# Two interface languages are supported: "en" or "ru"
ADMIN_LANGUAGE=en

SMTP_HOST=mail.your-domain.local
SMTP_PORT=25
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=taperotation@your-domain.ru
NOTIFY_EMAIL=admin@your-domain.ru
# Notify N days before tape set expiration
NOTIFY_DAYS_BEFORE=7
# Public application URL — used in email notification links
APP_URL=http://your-server:5174
# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://your-server:5174
